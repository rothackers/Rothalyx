set(CPACK_PACKAGE_NAME "zara-re-platform")
set(CPACK_PACKAGE_VENDOR "Zara")
set(CPACK_PACKAGE_CONTACT "https://github.com/regaan/Zara/issues")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "ZARA RE FRAMEWORK")
set(CPACK_PACKAGE_INSTALL_DIRECTORY "ZARA RE FRAMEWORK")
set(CPACK_PACKAGE_HOMEPAGE_URL "https://github.com/regaan/Zara")
set(CPACK_PACKAGE_VERSION "${PROJECT_VERSION}")
set(CPACK_PACKAGE_FILE_NAME "${CPACK_PACKAGE_NAME}-${PROJECT_VERSION}-${CMAKE_SYSTEM_NAME}-${CMAKE_SYSTEM_PROCESSOR}")
set(CPACK_RESOURCE_FILE_README "${CMAKE_SOURCE_DIR}/README.md")
set(CPACK_RESOURCE_FILE_LICENSE "${CMAKE_SOURCE_DIR}/LICENSE")
set(CPACK_PACKAGE_EXECUTABLES "zara_desktop_qt;ZARA RE FRAMEWORK" "zara_cli;Zara CLI")

if(WIN32)
    set(CPACK_NSIS_DISPLAY_NAME "ZARA RE FRAMEWORK")
    set(CPACK_NSIS_PACKAGE_NAME "ZARA RE FRAMEWORK")
    set(CPACK_NSIS_URL_INFO_ABOUT "https://github.com/regaan/Zara")
    set(CPACK_NSIS_CONTACT "https://github.com/regaan/Zara/issues")
    set(CPACK_NSIS_MUI_FINISHPAGE_RUN "zara_desktop_qt.exe")
    set(CPACK_NSIS_ENABLE_UNINSTALL_BEFORE_INSTALL ON)
    set(CPACK_NSIS_MUI_ICON "${CMAKE_SOURCE_DIR}/apps/desktop_qt/resources/zara-re-platform.ico")
    set(CPACK_NSIS_MUI_UNIICON "${CMAKE_SOURCE_DIR}/apps/desktop_qt/resources/zara-re-platform.ico")
    set(CPACK_NSIS_INSTALLED_ICON_NAME "bin\\\\zara_desktop_qt.exe")
endif()

if(APPLE)
    set(CPACK_DMG_VOLUME_NAME "ZARA RE FRAMEWORK")
    set(CPACK_DMG_DISABLE_APPLICATIONS_SYMLINK OFF)
endif()

if(UNIX AND NOT APPLE)
    set(CPACK_DEBIAN_FILE_NAME DEB-DEFAULT)
    set(CPACK_DEBIAN_PACKAGE_MAINTAINER "Zara")
    set(CPACK_DEBIAN_PACKAGE_HOMEPAGE "https://github.com/regaan/Zara")
    set(CPACK_DEBIAN_PACKAGE_SECTION "devel")
    set(CPACK_DEBIAN_PACKAGE_SHLIBDEPS ON)
endif()

include(CPack)
